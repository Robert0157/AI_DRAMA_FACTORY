# ========================================
# AI_DRAMA_FACTORY v8.7 環境配置範本
# ========================================
# 複製此檔為 .env 並填入實際密鑰
# 警告：.env 包含敏感密鑰，絕不提交 Git！
# ========================================

# 【基本設定】
WORKSPACE_ROOT=f:\AI_DRAMA_FACTORY
# Mac mini 正式根目錄（外接 SSD）
# WORKSPACE_ROOT=/Volumes/AI_Workspace/AI_Drama_Factory
# Mac mini 建議虛擬環境目錄（不一定要寫入 .env，可作部署約定）
# VENV_ROOT=/Volumes/AI_Workspace/envs/openclaw_project
TARGET_ENV=WINDOWS
SKIP_MOUNT_CHECK=false

# 【Midjourney API】
MJ_API_KEY=your-midjourney-key-here
MJ_BASE_URL=https://your-midjourney-endpoint.com

# 【可靈 (Kling) API】
KLING_AK=your-kling-access-key
KLING_SK=your-kling-secret-key

# 【智譜 GLM-4 API】(影片字幕 / 企劃書)
ZHIPUAI_API_KEY=your-glm4-api-key

# ========================================
# 【v8.7 新增：決策中樞 & 冷儲存】
# ========================================

# 【Telegram 決策層】
# 獲取方式：@BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhiJklmnoPqRstuvWxyz
TELEGRAM_CHAT_ID=your-private-chat-id

# 【AWS S3 冷儲存】(永久數位資產)
# 獲取方式：AWS IAM 控制台
AWS_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# 【Backblaze B2 冷儲存】(替代方案)
# 獲取方式：Backblaze B2 控制台
B2_ACCOUNT_ID=your-b2-account-id
B2_API_KEY=your-b2-api-key
B2_BUCKET_NAME=your-b2-bucket-name

# 【DistroKid RPA 配置】
# 提示：第一次手動登入並保存 Cookie，後續 RPA 將使用
DISTROKID_COOKIE_PATH=.cookies/distrokid.pkl
DISTROKID_ARTIST_NAME=R&S Echoes

# 【資產生命週期設定】
# MP4（短效期消耗品）：推流/上傳完成後 48 小時刪除
MP4_LIFESPAN_HOURS=48

# WAV（永久資產）：保留 7 天後上傳 S3/B2 冷儲存
WAV_LIFESPAN_DAYS=7

# 【每日配額】
# CEO 每日最多審核 10 首音軌，滿額後自動觸發 Phase 2
DAILY_UPLOAD_QUOTA=10

# ========================================
# 【備份鏡像 — 選填】與 GitHub Actions Secret 同名 BACKUP_MIRROR_URL
# ========================================
# 將主 repo 以 git push --mirror 同步到第二個 GitHub 空庫（需 PAT）。勿提交含 token 的完整 URL 至 Git。
# 本機執行：python scripts/maintenance/push_backup_mirror.py
# 說明：.github/BACKUP_REPO.md
# BACKUP_MIRROR_URL=https://x-access-token:YOUR_PAT@github.com/OWNER/AI_DRAMA_FACTORY_BACKUP.git

